# URL do Google Apps Script publicado como Web App
# Para obter essa URL:
#   1. Abra a planilha > Extensoes > Apps Script
#   2. Cole o conteudo de appscript/Code.gs
#   3. Implantar > Nova implantacao > Aplicativo da Web
#      - Executar como: Eu mesmo
#      - Quem tem acesso: Qualquer pessoa (anonimo)
#   4. Copie a URL e cole aqui
# IMPORTANTE: NEXT_PUBLIC_ expoe a variavel no browser (necessario para GitHub Pages)

NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/SEU_ID_AQUI/exec

# Necessario apenas para dev local se quiser simular o basePath do GitHub Pages
# NEXT_PUBLIC_BASE_PATH=/dashboard-grafico
